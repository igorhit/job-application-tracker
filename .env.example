# Backend — gerado automaticamente pelo EnvBootstrap na primeira execução local
# Em Docker, configurar via docker-compose.yml

# JWT (gerado automaticamente — não precisa configurar manualmente)
Jwt__Secret=your-secret-here

# Banco de dados SQLite
ConnectionStrings__DefaultConnection=Data Source=applicationtracker.db

# Seed de dados demo
DemoData__Enabled=true
DemoData__UserEmail=demo@tracker.dev
DemoData__UserPassword=Demo1234!

# CORS — origens permitidas para o frontend (separadas por vírgula)
Cors__AllowedOrigins=http://localhost:3000

# IA opcional via backend (desabilitada por padrão)
Ai__Enabled=false
Ai__Provider=OpenAI
Ai__Model=gpt-5-mini
Ai__BaseUrl=https://api.openai.com/v1/
Ai__ApiKey=
Ai__TimeoutSeconds=45

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5001
