{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=applicationtracker.db"
  },
  "Jwt": {
    "Issuer": "ApplicationTrackerAPI",
    "Audience": "ApplicationTrackerClients"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "POST:/auth/login",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/auth/register",
        "Period": "1h",
        "Limit": 5
      }
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "DemoData": {
    "Enabled": false,
    "UserEmail": "demo@tracker.dev",
    "UserPassword": "Demo1234!"
  },
  "AllowedHosts": "*"
}
